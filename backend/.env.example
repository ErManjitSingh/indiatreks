# Server
NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
APP_NAME=India Holiday Destinations API
APP_URL=https://api.treks.indiaholidaydestination.com
FRONTEND_URL=https://treks.indiaholidaydestination.com
ADMIN_URL=https://admin.indiaholidaydestination.com
CORS_ORIGINS=https://treks.indiaholidaydestination.com,https://indiaholidaydestination.com,http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://ihd_app:CHANGE_ME@127.0.0.1:27017/indiaholidaydestinations?authSource=indiaholidaydestinations
MONGODB_DB=indiaholidaydestinations

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=12h
JWT_REFRESH_EXPIRES=7d

# Redis (optional — leave blank to disable)
REDIS_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=indiaholidaydestinations

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="India Holiday Destinations <noreply@indiaholidaydestinations.com>"
ENQUIRY_EMAIL=indiaholidaydestinations.in@gmail.com

# Payments (Razorpay-ready)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth (ready)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
UPLOAD_MAX_MB=10

# Seed admin (used by seed:admin only)
SEED_SUPERADMIN_EMAIL=admin@indiaholidaydestinations.com
SEED_SUPERADMIN_PASSWORD=ChangeMe@12345
SEED_SUPERADMIN_NAME=Super Admin
